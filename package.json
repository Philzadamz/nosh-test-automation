{
  "name": "nosh-cypress-automation",
  "version": "1.0.0",
  "description": "End-to-end Cypress automation framework for Nosh gift card trading platform",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:auth": "cypress run --spec 'cypress/e2e/01_auth/**/*.cy.js'",
    "cy:run:dashboard": "cypress run --spec 'cypress/e2e/02_dashboard/**/*.cy.js'",
    "cy:run:giftcards": "cypress run --spec 'cypress/e2e/03_giftcards/**/*.cy.js'",
    "cy:run:wallet": "cypress run --spec 'cypress/e2e/04_wallet/**/*.cy.js'",
    "cy:run:transactions": "cypress run --spec 'cypress/e2e/05_transactions/**/*.cy.js'"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "cypress": "^13.17.0"
  }
}
